    "@types/uuid": "^9.0.7",
        "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "serverless": "^3.38.0",
    "serverless-webpack": "^5.13.0",
    "ts-jest": "^29.1.1",
