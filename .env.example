# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Redis Configuration (will be overridden by SSM parameters)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# S3 Configuration
S3_BUCKET_NAME=catalogo-pagos-csv

# Environment
NODE_ENV=dev
